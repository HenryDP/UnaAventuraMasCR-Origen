{
  "entities": {
    "quote": {
      "title": "Quote",
      "description": "A travel quote requested by a customer.",
      "type": "object",
      "properties": {
        "customerName": { "type": "string", "description": "Full name of the customer." },
        "customerEmail": { "type": "string", "format": "email", "description": "Email address of the customer." },
        "customerPhone": { "type": "string", "description": "Phone number of the customer." },
        "startDate": { "type": "string", "description": "Start date of the trip." },
        "endDate": { "type": "string", "description": "End date of the trip." },
        "peopleCount": { "type": "number", "description": "Number of people traveling." },
        "vehicleId": { "type": "string", "description": "ID of the selected vehicle." },
        "selectedDestinations": { "type": "array", "items": { "type": "string" }, "description": "List of selected destination IDs." },
        "selectedTours": { "type": "array", "items": { "type": "string" }, "description": "List of selected tour IDs." },
        "selectedExperiences": { "type": "array", "items": { "type": "string" }, "description": "List of selected experience IDs." },
        "includeHospedaje": { "type": "boolean", "description": "Whether to include lodging." },
        "includeAlimentacion": { "type": "array", "items": { "type": "string" }, "description": "List of included meals." },
        "includeGuia": { "type": "boolean", "description": "Whether to include a guide." },
        "totalPrice": { "type": "number", "description": "Final price calculated for the customer." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the quote was created." },
        "status": { "type": "string", "enum": ["pending", "contacted", "confirmed", "cancelled"], "description": "Status of the quote." }
      },
      "required": ["customerName", "customerEmail", "customerPhone", "startDate", "endDate", "peopleCount", "totalPrice"]
    }
  },
  "firestore": {
    "/quotes/{quoteId}": {
      "schema": "quote",
      "description": "Collection of travel quotes."
    }
  }
}
